{"t":"2026-06-29T16:04:41.044Z","tool":"write_workbench_file","args":{"path":"/workspace/app.js","content":"const express = require('express');\nconst bodyParser = require('body-parser');\nconst app = express();\nconst port = 3000;\n\n// Middleware to parse JSON bodies\napp.use(bodyParser.json());\napp.use(bodyParser.urlencoded({ extended: true }));\n\n// In-memory data store\nlet people = [];\n\n// Route to add a person\napp.post('/add', (req, res) => {\n    const { name, address, phone } = req.body;\n    people.push({ name, address, phone });\n    res.send('Person added successfully!');\n});\n\n// Route to search for a person by name\napp.get('/search', (req, res) => {\n    const { name } = req.query;\n    const result = people.filter(person => person.name.toLowerCase() === name.toLowerCase());\n    res.json(result);\n});\n\n// Start the server\napp.listen(port, () => {\n    console.log(`Server running at http://localhost:${port}`);\n});"},"status":"ok","ms":39}
