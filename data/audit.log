{"t":"2026-06-29T16:07:15.148Z","tool":"write_file","args":{"path":"simple_web_app_code.txt","content":"// server.js\nconst express = require('express');\nconst bodyParser = require('body-parser');\n\nconst app = express();\nconst PORT = 9101;\n\napp.use(bodyParser.json());\napp.use(express.static('public'));\n\nlet people = [];\n\napp.post('/add', (req, res) => {\n    const { name, address, phone } = req.body;\n    people.push({ name, address, phone });\n    res.status(201).send('Person added');\n});\n\napp.get('/search', (req, res) => {\n    const { name } = req.query;\n    const results = people.filter(person => person.name.toLowerCase().includes(name.toLowerCase()));\n    res.json(results);\n});\n\napp.listen(PORT, '0.0.0.0', () => {\n    console.log(`Server is running on http://localhost:${PORT}`);\n});\n\n// public/index.html\n<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Person Info</title>\n</head>\n<body>\n    <h1>Person Information</h1>\n    <form id=\"personForm\">\n        <input type=\"text\" id=\"name\" placeholder=\"Name\" required />\n        <input type=\"text\" id=\"address\" placeholder=\"Address\" required />\n        <input type=\"text\" id=\"phone\" placeholder=\"Phone\" required />\n        <button type=\"submit\">Add Person</button>\n    </form>\n    <hr />\n    <h2>Search</h2>\n    <input type=\"text\" id=\"searchName\" placeholder=\"Search by name\" />\n    <button id=\"searchBtn\">Search</button>\n    <button id=\"clearBtn\">Clear Search</button>\n    <div id=\"results\"></div>\n\n    <script>\n        document.getElementById('personForm').addEventListener('submit', function(e) {\n            e.preventDefault();\n            const name = document.getElementById('name').value;\n            const address = document.getElementById('address').value;\n            const phone = document.getElementById('phone').value;\n            fetch('/add', {\n                method: 'POST',\n                headers: { 'Content-Type': 'application/json' },\n                body: JSON.stringify({ name, address, phone })\n            }).then(response => {\n                if (response.ok) {\n                    alert('Person added!');\n                    document.getElementById('personForm').reset();\n                }\n            });\n        });\n\n        document.getElementById('searchBtn').addEventListener('click', function() {\n            const name = document.getElementById('searchName').value;\n            fetch(`/search?name=${name}`)\n                .then(response => response.json())\n                .then(data => {\n                    const resultsDiv = document.getElementById('results');\n                    resultsDiv.innerHTML = '';\n                    data.forEach(person => {\n                        resultsDiv.innerHTML += `<p>${person.name} - ${person.address} - ${person.phone}</p>`;\n                    });\n                });\n        });\n\n        document.getElementById('clearBtn').addEventListener('click', function() {\n            document.getElementById('searchName').value = '';\n            document.getElementById('results').innerHTML = '';\n        });\n    </script>\n</body>\n</html>"},"status":"ok","ms":2}
