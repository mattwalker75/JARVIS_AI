[
  {
    "name": "reasoning-math",
    "messages": [{ "role": "user", "content": "What is 17 * 23? Reply with just the number." }],
    "expect": { "contains": ["391"], "max_ms": 30000 }
  },
  {
    "name": "identity",
    "messages": [{ "role": "user", "content": "What is your name? Answer in one word." }],
    "expect": { "contains": ["JARVIS"] }
  },
  {
    "name": "tool-shell",
    "messages": [{ "role": "user", "content": "Use your shell to echo the exact text ROGER123, then tell me what it printed." }],
    "expect": { "contains": ["ROGER123"], "tools_used": ["run_shell"], "max_cost_usd": 0.02 }
  },
  {
    "name": "tool-memory-recall",
    "messages": [{ "role": "user", "content": "Search your memory and tell me what city I live in." }],
    "expect": { "tools_used": ["search_memory"] }
  }
]
